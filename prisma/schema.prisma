// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/prisma-generated"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  news      News[]
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String   @default("")
  /// Optional hero/portrait image URL or site path (e.g. /uploads/...). Used for Principal’s Message when slug is principal-message.
  featuredImage  String?
  metaTitle      String?
  metaDescription String?
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @default("")
  excerpt     String?
  image       String?
  publishedAt DateTime?
  featured    Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  parentAlbumId String?
  parentAlbum GalleryAlbum? @relation("AlbumHierarchy", fields: [parentAlbumId], references: [id], onDelete: Cascade)
  childAlbums GalleryAlbum[] @relation("AlbumHierarchy")
  images      GalleryImage[]
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String?
  image       String
  albumId     String
  album       GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  file        String
  category    String?
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  designation String
  testimonial String
  image       String?
  displayOrder Int     @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NoticeBoardEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime
  displayOrder Int     @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NoticeBoardNotice {
  id          String   @id @default(cuid())
  title       String
  content     String?  // for Text notices (or extra description)
  noticeType  String   // "document" | "image" | "text"
  pdfUrl      String?  // required when noticeType == "document"
  imageUrl    String?  // optional when noticeType == "image"
  publishDate DateTime @default(now())
  expiryDate  DateTime?
  active      Boolean  @default(true)
  important   Boolean  @default(false)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseApplication {
  id             String   @id @default(cuid())
  applicationNo  String   @unique
  studentName    String
  mobile         String
  email          String
  courseCode     String
  courseName     String
  batchYear      Int      @default(0)
  batchNo        Int      @default(1) // 1 | 2 | 3
  department     String?
  qualification  String?
  mode           String   // "online" | "offline"
  message        String?
  status         String   @default("Pending") // Pending | Approved | Rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FlashNews {
  id          String   @id @default(cuid())
  title       String
  description String?
  file        String?
  fileType    String?  // "image" or "pdf"
  displayOrder Int     @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id          String   @id @default(cuid())
  image       String
  caption     String?
  displayOrder Int     @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShortTermCourse {
  id          String   @id @default(cuid())
  title       String
  code        String?
  description String?
  image       String?
  duration    String?
  fees        String?
  displayOrder Int     @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PopupBanner {
  id          String   @id @default(cuid())
  title       String
  content     String   // HTML content
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaffProfile {
  id          String   @id @default(cuid())
  name        String
  designation String
  department  String   // e.g., "Education", "English", "Botany", etc.
  stream      String?  // Optional for non-teaching staff
  category    String   @default("teaching") // "teaching" or "non-teaching"
  photo       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NavigationMenu {
  id        String           @id @default(cuid())
  title     String
  href      String?
  order     Int              @default(0)
  isVisible Boolean          @default(true)
  parentId  String?
  parent    NavigationMenu?  @relation("NavigationMenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  NavigationMenu[] @relation("NavigationMenuChildren")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model QuestionPaper {
  id            String   @id @default(cuid())
  academicYear  String
  department    String
  programme     String   @default("B.A.")
  semester      Int      @default(1)
  courseName    String
  courseCode    String
  examType      String
  examMonth     String?
  examYear      Int
  description   String?
  fileUrl       String
  originalName  String
  fileType      String?
  fileSize      Int?
  downloadCount Int      @default(0)
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([academicYear, department, programme, semester, courseCode, examType, examYear])
  @@index([department, examYear, published])
  @@index([published, academicYear])
}

model Syllabus {
  id                String   @id @default(cuid())
  department        String
  programme         String
  academicYear      String
  curriculumVersion String?
  semester          Int
  courseCode        String
  courseName        String
  description       String?
  fileUrl           String
  originalName      String
  fileSize          Int?
  published         Boolean  @default(false)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([department, programme, semester, courseCode, academicYear])
  @@index([department, programme, semester])
  @@index([published, academicYear])
}

model Grievance {
  id         String   @id @default(cuid())
  category   String
  fullName   String
  email      String
  phone      String?
  message    String
  createdAt  DateTime @default(now())
}

model BloodDonor {
  id                String   @id @default(cuid())
  fullName          String
  dateOfBirth       DateTime
  gender            String?
  phone             String
  email             String
  bloodGroup        String
  lastDonationDate  DateTime?
  addressStreet     String?
  addressCity       String?
  addressState      String?
  addressPostalCode String?
  medicalNotes      String?
  consent           Boolean  @default(false)
  preferredContact  String
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
}

/// Public alumni registration submissions (exportable by admin).
model AlumniRegistration {
  id        String @id @default(cuid())
  createdAt DateTime @default(now())

  fullName   String
  gender     String
  dateOfBirth DateTime
  profilePhoto String?

  email              String
  mobileNumber       String
  alternatePhone     String?
  currentAddress     String
  cityStateCountry   String

  courseProgram         String
  department            String
  yearOfAdmission       Int
  yearOfGraduation      Int
  enrollmentRollNumber  String

  currentOccupation        String
  companyOrganizationName  String?
  jobTitle                 String?
  workLocation             String?
  yearsOfExperience        String?

  linkedInProfile       String?
  socialMedia           String?
  personalWebsite     String?

  willingToMentor       Boolean @default(false)
  interestedInEvents    Boolean @default(false)
  areasOfInterest       String?

  achievementsAwards    String?
  suggestionsFeedback   String?
  messageToInstitution  String?

  declarationAccepted Boolean @default(false)

  ipAddress  String?
  userAgent  String?
}
