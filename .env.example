# Copy to .env and fill in values before deploy.
# Production site: https://donboscocollege.ac.in

# Database (SQLite — path is relative to prisma/ folder)
DATABASE_URL="file:./dev.db"

# Public URLs — must match how users access the site (HTTPS, no trailing slash)
NEXTAUTH_URL="https://donboscocollege.ac.in"
NEXT_PUBLIC_SITE_URL="https://donboscocollege.ac.in"

# Auth (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-min-32-characters-long-secret"

# SMTP (required for grievances, blood donors, notice alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="principal@donboscocollege.ac.in"

# reCAPTCHA (register keys for donboscocollege.ac.in)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Email routing
NOTICE_ALERT_TO=
GRIEVANCE_FORWARD_TO=
CONTACT_FORWARD_TO=
BLOOD_DONOR_ADMIN_EMAIL=

# Initial admin — run: npm run admin:set-password (requires ADMIN_PASSWORD, min 12 chars)
ADMIN_EMAIL="admin@donboscocollege.ac.in"
ADMIN_PASSWORD=
